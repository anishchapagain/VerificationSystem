# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Signature Verifier API"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/signature_db

# ─── ML Model ─────────────────────────────────────────────────────────────────
MODEL_BACKEND=custom
# MODEL_WEIGHTS_PATH=weights/siamese_best.pt
MODEL_WEIGHTS_PATH=weights/siamese_cedar.pt
EMBEDDING_DIM=512
MATCH_THRESHOLD=0.85
DEVICE=cpu # cuda | cpu — auto-detected if not set

# ─── Storage ──────────────────────────────────────────────────────────────────
SIGNATURE_STORAGE_PATH=storage/signatures
FAISS_INDEX_PATH=storage/embeddings/index.faiss

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:8501","http://127.0.0.1:8501"]

# ─── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-a-64-char-random-string-in-production
ALGORITHM=HS256
TOKEN_EXPIRE_MINUTES=60

# ─── Video ────────────────────────────────────────────────────────────────────
VIDEO_FRAME_STRIDE=5
VIDEO_TOP_FRAMES=3
